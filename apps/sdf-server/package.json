{
    "name": "@etapsky/sdf-server",
    "version": "0.1.0",
    "description": "SDF REST API server — Fastify, BullMQ, S3/MinIO, PostgreSQL",
    "author": "Yunus YILDIZ <yunus.yildiz@etapsky.com>",
    "license": "BUSL-1.1",
    "buslChangeDate": "2030-03-17",
    "buslChangeLicense": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/etapsky/sdf.git",
        "directory": "apps/sdf-server"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc --project tsconfig.build.json",
        "dev": "tsx watch --env-file=.env --ignore='**/node_modules/**' src/index.ts",
        "start": "node --env-file=.env dist/index.js",
        "typecheck": "tsc --noEmit",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@etapsky/sdf-kit": "^0.2.2",
        "@etapsky/sdf-schema-registry": "^0.1.0",
        "@fastify/cors": "^10.0.1",
        "@fastify/multipart": "^9.0.1",
        "@fastify/rate-limit": "^10.2.1",
        "bullmq": "^5.13.0",
        "drizzle-orm": "^0.41.0",
        "fastify": "^5.3.2",
        "ioredis": "^5.4.1",
        "pg": "^8.13.3",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.6",
        "drizzle-kit": "^0.30.4",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.19.3",
        "typescript": "^5.7.3"
    }
}
