{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "bun run build",
      "problemMatcher": "$tsc",
      "label": "npm: build",
      "group": "build"
    },
    {
      "type": "shell",
      "command": "bun run watch",
      "problemMatcher": "$tsc-watch",
      "label": "npm: watch",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
