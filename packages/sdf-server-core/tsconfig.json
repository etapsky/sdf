// Base compiler options shared by dev (tsx) and production build (tsconfig.build).
{
    "compilerOptions": {
      "target":            "ES2022",
      "module":            "ESNext",
      "moduleResolution":  "bundler",
      "strict":            true,
      "esModuleInterop":   true,
      "skipLibCheck":      true,
      "resolveJsonModule": true,
      "types":             ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
  }
