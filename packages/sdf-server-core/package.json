{
    "name": "@etapsky/sdf-server-core",
    "version": "0.1.6",
    "description": "SDF server-side business logic — Fastify, BullMQ, S3/MinIO, PostgreSQL, ERP Connectors",
    "author": "Yunus YILDIZ <yunus.yildiz@etapsky.com>",
    "license": "BUSL-1.1",
    "buslChangeDate": "2030-03-17",
    "buslChangeLicense": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/etapsky/sdf.git",
        "directory": "packages/sdf-server-core"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./queue": {
            "import": "./dist/queue/client.js",
            "types": "./dist/queue/client.d.ts"
        },
        "./queue/jobs": {
            "import": "./dist/queue/jobs.js",
            "types": "./dist/queue/jobs.d.ts"
        },
        "./config": {
            "import": "./dist/config/env.js",
            "types": "./dist/config/env.d.ts"
        },
        "./db": {
            "import": "./dist/db/client.js",
            "types": "./dist/db/client.d.ts"
        },
        "./db/schema": {
            "import": "./dist/db/schema.js",
            "types": "./dist/db/schema.d.ts"
        },
        "./storage": {
            "import": "./dist/storage/s3.js",
            "types": "./dist/storage/s3.d.ts"
        },
        "./middleware/auth": {
            "import": "./dist/middleware/auth.js",
            "types": "./dist/middleware/auth.d.ts"
        },
        "./connectors": {
            "import": "./dist/connectors/index.js",
            "types": "./dist/connectors/index.d.ts"
        },
        "./api": {
            "import": "./dist/api/server.js",
            "types": "./dist/api/server.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.build.json",
        "dev": "tsc --project tsconfig.build.json --watch",
        "prepublishOnly": "npm run build",
        "typecheck": "tsc --noEmit",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@etapsky/sdf-kit": "^0.2.2",
        "@etapsky/sdf-schema-registry": "^0.1.0",
        "@fastify/cors": "^10.0.1",
        "@fastify/multipart": "^9.0.1",
        "@fastify/rate-limit": "^10.2.1",
        "bullmq": "^5.13.0",
        "drizzle-orm": "^0.41.0",
        "fastify": "^5.3.2",
        "ioredis": "^5.4.1",
        "pg": "^8.13.3",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.6",
        "drizzle-kit": "^0.30.4",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.19.3",
        "typescript": "^5.7.3"
    }
}
