{
  "name": "@etapsky/sdf-cli",
  "version": "0.1.4",
  "description": "SDF command-line tool — inspect, validate, convert .sdf files",
  "author": "Yunus YILDIZ <yunus.yildiz@etapsky.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
